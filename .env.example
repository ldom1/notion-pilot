# Telegram bot token from @BotFather
TELEGRAM_BOT_TOKEN=   # optional if using email or discord adapter

# Notion internal integration token (secret_...)
NOTION_TOKEN=

# Notion database ID (UUID; 32 hex from the page URL is normalized to dashed UUID)
NOTION_TELEGRAM_MSG_DATABASE_ID=
NOTION_TITLE_PROPERTY=Name

# Notion people database ID
NOTION_PEOPLE_DATABASE_ID=
NOTION_COMPANIES_DATA_SOURCE_ID=

# Optional: force a specific data source (linked DBs); else a source whose schema matches is used
# NOTION_DATA_SOURCE_ID=

# Optional: title column name if not "Title" (Notion default is often "Name")
# NOTION_TITLE_PROPERTY=Title

# Optional: faster-whisper defaults for voice notes
# WHISPER_LANGUAGE=fr
# WHISPER_MODEL_SIZE=base

# OpenRouter (interprets messages for Notion Title, Label, Type, URL, Description, Interest)
OPENROUTER_API_KEY=
# OPENROUTER_MODEL=google/gemini-2.5-flash-lite
# OPENROUTER_HTTP_REFERER=https://github.com/ldom1/telegram-to-notion
# OPENROUTER_APP_TITLE=telegram-to-notion  ← optional, default already set

# ── Email / IMAP (optional) ──────────────────────────────────────────────────
# IMAP_HOST=imap.gmail.com
# IMAP_PORT=993
# IMAP_USER=you@gmail.com
# IMAP_PASSWORD=your-app-password
# IMAP_INBOX=INBOX
# IMAP_PROMOTIONS_FOLDER=Promotions
# IMAP_SINCE_DAYS=7
# IMAP_ARCHIVE=Archive
# IMAP_POLL_INTERVAL=60
# IMAP_ALLOWED_SENDERS=@medium.com,@tldrnewsletter.com   # suffix match; → NOTION_TELEGRAM_MSG_DATABASE_ID
# IMAP_AUTO_ARCHIVE_SENDERS=@e.vivinomail.com,members@medium.com,partnerprogram@medium.com
# IMAP_PEOPLE_SENDERS=@gmail.com,@hotmail.com,@icloud.com,@yahoo.com  # personal emails → people DB
# IMAP_SEND_EMAIL_TO_USER=true

# ── Discord (optional) ───────────────────────────────────────────────────────
# DISCORD_BOT_TOKEN=your-discord-bot-token
# DISCORD_CHANNEL_ID=123456789012345678

# ── Web search (optional) ───────────────────────────────────────────────────────
# BRAVE_API_KEY=
