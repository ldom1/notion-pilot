FROM python:3.12-slim

# Install uv
COPY --from=ghcr.io/astral-sh/uv:latest /uv /usr/local/bin/uv

WORKDIR /app

# Prevents hatch-vcs from failing when there is no git history in the build context
ENV SETUPTOOLS_SCM_PRETEND_VERSION=0.0.0

# Install dependencies only first (cached layer — rebuilds only when pyproject.toml / uv.lock change)
COPY pyproject.toml uv.lock ./
RUN uv sync --frozen --no-dev --no-install-project

# Copy source and install the project itself
COPY . .
RUN uv sync --frozen --no-dev

EXPOSE 8080

CMD ["uv", "run", "uvicorn", "web.server:app_factory", "--factory", \
     "--host", "0.0.0.0", "--port", "8080"]
